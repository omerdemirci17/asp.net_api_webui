@model List<ResultServiceDTO>

    
<section id="features" class="features section">
    <div class="container">
        <!-- Sekmeler -->
        <ul class="nav nav-tabs row d-flex" data-aos="fade-up" data-aos-delay="100">
            @for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];
                <li class="nav-item col-3">
                    <a class="nav-link @(i == 0 ? "active show" : "")"
                       data-bs-toggle="tab"
                       data-bs-target="#features-tab-@item.ServiceID">
                        <i class="@item.Icon"></i>
                        <h4 class="d-none d-lg-block">@item.Title</h4>
                    </a>
                </li>
            }
        </ul>

        <!-- İçerikler -->
        <div class="tab-content" data-aos="fade-up" data-aos-delay="200">
            @for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];
                <div class="tab-pane fade @(i == 0 ? "active show" : "")"
                     id="features-tab-@item.ServiceID">
                    <div class="row">
                        <div class="col-lg-6 order-2 order-lg-1 mt-3 mt-lg-0">
                            <h3>@item.Title</h3>
                            <p class="fst-italic">@item.Description</p>
                        </div>
                        <div class="col-lg-6 order-1 order-lg-2 text-center">
                            <img src="~/Dewi-1.0.0/assets/img/working-1.jpg" alt="" class="img-fluid">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@model List<AssignRoleDTO>
@{
    ViewData["Title"] = "Assign Role Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<title>@ViewData["Title"]</title>
<form method="post">

    @for(int i=0;i<Model.Count; i++)
    {
        <div class="form-check">
            <input type="hidden" asp-for="@Model[i].RoleId"/>
            <input type="hidden" asp-for="@Model[i].RoleName" />
            <input type="checkbox" asp-for="@Model[i].RoleExist" class="form-check" />
            <label class="form-check-label" for="@Model[i].RoleExist">@Model[i].RoleName</label>

        </div>
    }
    <button class="btn btn-outline-primary">Assign Role</button>
</form>




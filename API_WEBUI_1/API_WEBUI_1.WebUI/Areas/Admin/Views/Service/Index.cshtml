@model List<ResultServiceDTO>

@{
    ViewData["Title"] = "Service Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>

<table class="table table-hover">
    <thead>
        <tr>
            <th>#</th>
            <th>Icon</th>
            <th>Title</th>
            <th>Description</th>
            <th>Service Category</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ServiceID</td>
                <td>@item.Icon</td>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.ServiceCategory?.Name</td>
                <td>
                    <button onclick="DeleteCheck('Admin', 'Service', 'Delete', @item.ServiceID)" class="btn btn-outline-danger">Delete</button>
                    <a asp-action="UpdateService" asp-controller="Service" asp-area="Admin" asp-route-id="@item.ServiceID" class="btn btn-outline-info">Update</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<br />
<a asp-action="CreateService" asp-controller="Service" asp-area="Admin" class="btn btn-outline-primary">Create New Service</a>

@model UpdateTestimonialDto
@{
    ViewData["Title"] = "Update Testimonial Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>
<form method="post" asp-action="UpdateTestimonial" asp-controller="Testimonial" asp-area="Admin">
    <input type="hidden" asp-for="TestimonialId" />

    <label>Testimonial Name</label>
    <input type="text" asp-for="TestimonialName" class="form-control" />
    <br />

    <label>Title</label>
    <input type="text" asp-for="Title" class="form-control" />
    <br />

    <label>Image Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" />
    <br />

    <label>Comment</label>
    <textarea asp-for="Comment" class="form-control"></textarea>
    <br />

    <label>Star</label>
    <input type="number" asp-for="Star" class="form-control" min="0" max="5" />
    <br />

    <button class="btn btn-outline-primary">Save</button>
</form>

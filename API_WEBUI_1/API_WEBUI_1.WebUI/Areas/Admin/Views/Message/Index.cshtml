@model List<ResultMessageDTO>

@{
    ViewData["Title"] = "Message Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>

<table class="table table-hover">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Subject</th>
            <th>Content</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MessageId</td>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Subject</td>
                <td>@item.Content</td>
                <td>
                    <button onclick="DeleteCheck('Admin', 'Message', 'Delete', @item.MessageId)" class="btn btn-outline-danger">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<br />

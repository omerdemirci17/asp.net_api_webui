
@model CreateCustomerDTO
@{
    ViewData["Title"] = "Create Customer Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form method="post" asp-action="CreateCustomer" asp-controller="Customer" asp-area="Admin">
    <input type="hidden" asp-for="CustomerId" class="form-control"/>
    <label>First Name</label>
    <input type="text" asp-for="FirstName" class="form-control" />
    <br />

    <label>Last Name</label>
    <input type="text" asp-for="LastName" class="form-control" />
    <br />

    <label>Address</label>
    <input type="text" asp-for="Address" class="form-control" />
    <br />

    <label>Phone Number</label>
    <input type="text" asp-for="PhoneNumber" class="form-control" />
    <br />

    <label>Register Date</label>
    <input type="date" asp-for="RegistrationDate" class="form-control" />
    <br />

    <button type="submit" class="btn btn-outline-primary">Save</button>
</form>

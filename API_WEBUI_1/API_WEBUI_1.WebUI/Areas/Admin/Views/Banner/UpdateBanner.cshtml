@model UpdateBannerDto
@{
    ViewData["Title"] = "Update Banner Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>
<form method="post" asp-action="UpdateBanner" asp-controller="Banner" asp-area="Admin">
    <input type="hidden" asp-for="BannerID" />

    <label>Title</label>
    <input type="hidden" name="BannerId" value="" />
    <input type="text" asp-for="Title" class="form-control" />
    <br />

    <label>Image Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" />
    <br />

    <button class="btn btn-outline-primary">Save</button>
</form>

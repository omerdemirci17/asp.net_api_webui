@model List<ResultAboutDTO>
@{
    ViewData["Title"] = "About Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>

<table class="table table-hover">
    <tr>
        <th>#</th>
        <th>Description</th>
        <th>Image Url 1</th>
        <th>Image Url 2</th>
        <th>Item 1</th>
        <th>Item 2</th>
        <th>Item 3</th>
        <th>Item 4</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.AboutId</td>
            <td>@item.Description</td>
            <td>@item.ImageUrl1</td>
            <td>@item.ImageUrl2</td>
            <td>@item.Item1</td>
            <td>@item.Item2</td>
            <td>@item.Item3</td>
            <td>@item.Item4</td>
            <td>
                <button onclick="DeleteCheck('Admin', 'About', 'Delete', @item.AboutId)" class="btn btn-outline-danger">Delete</button>
                <a asp-action="UpdateAbout" asp-controller="About" asp-area="Admin" asp-route-id="@item.AboutId" class="btn btn-outline-info">Update</a>
            </td>
        </tr>
    }
</table>

<br />
<a asp-action="CreateAbout" asp-controller="About" asp-area="Admin" class="btn btn-outline-primary">Create New About</a>

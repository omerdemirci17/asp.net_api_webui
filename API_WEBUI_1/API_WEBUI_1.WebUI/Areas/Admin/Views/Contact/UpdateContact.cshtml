@model UpdateContactDto
@{
    ViewData["Title"] = "Update Contact Page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<title>@ViewData["Title"]</title>
<form method="post" asp-action="UpdateContact" asp-controller="Contact" asp-area="Admin">
    <input type="hidden" asp-for="ContactId" />

    <label>Map Url</label>
    <input type="text" asp-for="MapUrl" class="form-control" />
    <br />

    <label>Address</label>
    <input type="text" asp-for="Adress" class="form-control" />
    <br />

    <label>Phone</label>
    <input type="text" asp-for="Phone" class="form-control" />
    <br />

    <label>Email</label>
    <input type="email" asp-for="Email" class="form-control" />
    <br />

    <button class="btn btn-outline-primary">Save</button>
</form>
